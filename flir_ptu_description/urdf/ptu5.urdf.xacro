<?xml version="1.0"?>
<robot name="ptu_5" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- FLIR PTU-5 compact pan-tilt unit.
       Joint limits and velocities taken from the PTU-5 user manual:
         Pan  : +/- 178 deg  (~+/- 3.106 rad)
         Tilt : +31 / -81 deg (+0.541 / -1.414 rad)
         Max speed: ~60 deg/s (~1.047 rad/s) -->

  <xacro:property name="pan_velocity" value="1.047" />
  <xacro:property name="pan_range" value="3.106" />
  <xacro:property name="tilt_velocity" value="1.047" />
  <xacro:property name="tilt_up_range" value="0.541" />
  <xacro:property name="tilt_down_range" value="1.414" />
  <xacro:property name="joint_effort" value="10" />

  <xacro:macro name="ptu5_transmission" params="name">
    <transmission name="${name}_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${name}">
        <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
      </joint>
      <actuator name="${name}_motor">
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>
  </xacro:macro>

  <xacro:macro name="ptu_5" params="name pan_offset:=0.0">
    <!-- Stationary base housing (contains the pan motor). -->
    <link name="${name}_base_link">
      <inertial>
        <mass value="0.2" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
      </inertial>
      <visual>
        <material name="ptu5_body_color">
          <color rgba="0.3 0.3 0.3 1.0" />
        </material>
        <geometry>
          <mesh filename="package://flir_ptu_description/meshes/flir-ptu5-base.stl"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://flir_ptu_description/meshes/flir-ptu5-base.stl"/>
        </geometry>
      </collision>
    </link>
    <gazebo reference="${name}_base_link">
      <material>Gazebo/DarkGrey</material>
    </gazebo>

    <!-- Shell that rotates with pan; contains the tilt mechanism. -->
    <link name="${name}_pan_link">
      <inertial>
        <mass value="0.25" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
      </inertial>
      <visual>
        <material name="ptu5_body_color">
          <color rgba="0.3 0.3 0.3 1.0" />
        </material>
        <geometry>
          <mesh filename="package://flir_ptu_description/meshes/flir-ptu5-pan.stl"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://flir_ptu_description/meshes/flir-ptu5-pan.stl"/>
        </geometry>
      </collision>
    </link>
    <gazebo reference="${name}_pan_link">
      <material>Gazebo/DarkGrey</material>
    </gazebo>

    <!-- Top bracket / payload mount that tilts. -->
    <link name="${name}_tilt_link">
      <inertial>
        <mass value="0.05" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="1e-05" ixy="0" ixz="0" iyy="1e-05" iyz="0" izz="1e-05" />
      </inertial>
      <visual>
        <material name="ptu5_body_color">
          <color rgba="0.3 0.3 0.3 1.0" />
        </material>
        <geometry>
          <mesh filename="package://flir_ptu_description/meshes/flir-ptu5-tilt.stl"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://flir_ptu_description/meshes/flir-ptu5-tilt.stl"/>
        </geometry>
      </collision>
    </link>
    <gazebo reference="${name}_tilt_link">
      <material>Gazebo/DarkGrey</material>
    </gazebo>

    <!-- Convenient attachment point for payloads (camera, etc.). -->
    <link name="${name}_mount_link">
      <inertial>
        <mass value="2e-06"/>
        <inertia ixx="1.1e-09" ixy="0" ixz="0" iyy="1.1e-09" iyz="0" izz="1.1e-09"/>
      </inertial>
    </link>

    <!-- Pan joint: rotates the shell about the vertical (Z) axis. -->
    <joint name="${name}_pan" type="revolute">
      <parent link="${name}_base_link" />
      <child link="${name}_pan_link" />
      <origin xyz="0 0 0" rpy="0 0 ${pan_offset}" />
      <axis xyz="0 0 1" />
      <limit lower="${-pan_range}" upper="${pan_range}"
             effort="${joint_effort}" velocity="${pan_velocity}" />
    </joint>

    <xacro:ptu5_transmission name="${name}_pan" />

    <!-- Tilt joint: rotates the top bracket about the pitch (Y) axis. -->
    <joint name="${name}_tilt" type="revolute">
      <parent link="${name}_pan_link" />
      <child link="${name}_tilt_link" />
      <origin xyz="0.00975 0 0.0976" rpy="0 0 0" />
      <axis xyz="0 -1 0" />
      <limit lower="${-tilt_down_range}" upper="${tilt_up_range}"
             effort="${joint_effort}" velocity="${tilt_velocity}" />
    </joint>

    <xacro:ptu5_transmission name="${name}_tilt" />

    <!-- Fixed joint to provide an attachment point for accessories. -->
    <joint name="${name}_mount" type="fixed">
      <parent link="${name}_tilt_link"/>
      <child link="${name}_mount_link"/>
      <origin xyz="0 0 0.0757" rpy="0 0 0" />
    </joint>

    <!--
      Simulation support for Gazebo (gz-sim):
      - JointPositionController drives the pan/tilt joints from a Float64
        position command (rad) on gz topics ${name}/cmd_pan and ${name}/cmd_tilt.
      - JointStatePublisher exposes pan/tilt positions on ${name}/joint_states.
      These plugins are only loaded by Gazebo and have no effect on real hardware.
    -->
    <gazebo>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>${name}_pan</joint_name>
        <topic>${name}/cmd_pan</topic>
        <p_gain>5.0</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>0.5</d_gain>
        <i_max>1.0</i_max>
        <i_min>-1.0</i_min>
        <cmd_max>10.0</cmd_max>
        <cmd_min>-10.0</cmd_min>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>${name}_tilt</joint_name>
        <topic>${name}/cmd_tilt</topic>
        <p_gain>5.0</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>0.5</d_gain>
        <i_max>1.0</i_max>
        <i_min>-1.0</i_min>
        <cmd_max>10.0</cmd_max>
        <cmd_min>-10.0</cmd_min>
      </plugin>
      <plugin filename="gz-sim-joint-state-publisher-system"
              name="gz::sim::systems::JointStatePublisher">
        <joint_name>${name}_pan</joint_name>
        <joint_name>${name}_tilt</joint_name>
        <topic>${name}/joint_states</topic>
      </plugin>
    </gazebo>

  </xacro:macro>
</robot>
